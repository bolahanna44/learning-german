<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Learning German · Login</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&display=swap" rel="stylesheet">
    <style>
      body {
        font-family: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        margin: 0;
        min-height: 100vh;
        background: radial-gradient(circle at top, #f3f4ff, #e5e7fb 45%, #dfe3f3 100%);
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .card {
        width: min(420px, 90vw);
        background: #fff;
        border-radius: 18px;
        box-shadow: 0 20px 55px rgba(46, 56, 120, 0.12);
        padding: 32px;
      }
      h1 {
        margin-top: 0;
        font-weight: 600;
        color: #111827;
        font-size: 1.6rem;
      }
      form {
        display: flex;
        flex-direction: column;
        gap: 16px;
      }
      label {
        font-size: 0.95rem;
        color: #374151;
        display: flex;
        flex-direction: column;
        gap: 6px;
      }
      input {
        padding: 12px 14px;
        border-radius: 10px;
        border: 1px solid #cdd5ea;
        font-size: 1rem;
      }
      button {
        background: #3730a3;
        color: #fff;
        border: none;
        border-radius: 12px;
        padding: 12px;
        font-size: 1rem;
        cursor: pointer;
        transition: background 0.2s ease;
      }
      button:hover {
        background: #31258f;
      }
      .note {
        margin-top: 16px;
        font-size: 0.9rem;
        color: #4b5563;
      }
      .alert {
        padding: 10px 12px;
        border-radius: 10px;
        background: #fee2e2;
        color: #b91c1c;
        font-size: 0.9rem;
        margin-bottom: 16px;
      }
      .success {
        background: #dcfce7;
        color: #15803d;
      }
      a {
        color: #4338ca;
        text-decoration: none;
        font-weight: 500;
      }
    </style>
  </head>
  <body>
    <div class="card">
      <h1>Welcome back</h1>
      <% if (error) { %>
        <div class="alert">Login failed. Please double-check your email and password.</div>
      <% } %>
      <% if (message === 'registered') { %>
        <div class="alert success">Registration successful. You can log in now.</div>
      <% } else if (message === 'logged-out') { %>
        <div class="alert success">You have been logged out.</div>
      <% } %>
      <form method="POST" action="/login">
        <label>
          Email
          <input type="email" name="email" required autofocus />
        </label>
        <label>
          Password
          <input type="password" name="password" required />
        </label>
        <button type="submit">Sign in</button>
      </form>
      <p class="note">Need an account? <a href="/register">Register now</a>.</p>
    </div>
  </body>
</html>
