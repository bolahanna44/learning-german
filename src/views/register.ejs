<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Learning German · Register</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&display=swap" rel="stylesheet">
    <style>
      body {
        font-family: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        margin: 0;
        min-height: 100vh;
        padding: 24px;
        background: radial-gradient(circle at top, #fdf2f8, #f5d0fe 45%, #f8bbff 100%);
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .card {
        width: min(460px, 92vw);
        background: #fff;
        border-radius: 18px;
        box-shadow: 0 20px 55px rgba(180, 70, 160, 0.18);
        padding: 32px;
      }
      h1 {
        margin-top: 0;
        font-weight: 600;
        color: #701a75;
      }
      form {
        display: flex;
        flex-direction: column;
        gap: 16px;
      }
      label {
        font-size: 0.95rem;
        color: #4c1d95;
        display: flex;
        flex-direction: column;
        gap: 6px;
      }
      input {
        padding: 12px 14px;
        border-radius: 10px;
        border: 1px solid #e9d5ff;
        font-size: 1rem;
      }
      button {
        background: #c026d3;
        color: #fff;
        border: none;
        border-radius: 12px;
        padding: 12px;
        font-size: 1rem;
        cursor: pointer;
        transition: background 0.2s ease;
      }
      button:hover {
        background: #a21caf;
      }
      .alert {
        padding: 10px 12px;
        border-radius: 10px;
        background: #fee2e2;
        color: #b91c1c;
        font-size: 0.9rem;
        margin-bottom: 16px;
      }
      .note {
        margin-top: 16px;
        font-size: 0.9rem;
        color: #5b21b6;
      }
      a {
        color: #9333ea;
        text-decoration: none;
        font-weight: 500;
      }
    
      @media (max-width: 520px) {
        body {
          padding: 16px;
        }
        .card, .wrap, .box {
          padding: 24px 18px;
          width: 100% !important;
        }
        h1 {
          font-size: 1.35rem;
        }
      }
    </style>
  </head>
  <body>
    <div class="card">
      <h1>Create your account</h1>
      <% if (error === 'missing') { %>
        <div class="alert">Please provide both email and password.</div>
      <% } else if (error === 'exists') { %>
        <div class="alert">That email is already registered. Try logging in.</div>
      <% } else if (error === 'server') { %>
        <div class="alert">Something went wrong. Please try again.</div>
      <% } %>
      <form method="POST" action="/register">
        <label>
          Email
          <input type="email" name="email" required autofocus />
        </label>
        <label>
          Password
          <input type="password" name="password" required minlength="6" />
        </label>
        <button type="submit">Register</button>
      </form>
      <p class="note">Already signed up? <a href="/login">Go to login</a>.</p>
    </div>
  </body>
</html>
