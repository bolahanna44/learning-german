<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Learning German · Dashboard</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&display=swap" rel="stylesheet">
    <style>
      body {
        font-family: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        margin: 0;
        min-height: 100vh;
        padding: 24px;
        background: linear-gradient(135deg, #e0f2fe, #ede9fe);
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .wrap {
        width: min(600px, 92vw);
        background: #fff;
        border-radius: 20px;
        padding: 40px;
        box-shadow: 0 25px 60px rgba(15, 23, 42, 0.12);
        text-align: center;
      }
      h1 {
        margin-top: 0;
        color: #0f172a;
      }
      p {
        color: #475569;
        font-size: 1.05rem;
      }
      form {
        margin-top: 24px;
      }
      button {
        background: #0ea5e9;
        color: #fff;
        border: none;
        border-radius: 999px;
        padding: 12px 32px;
        font-size: 1rem;
        cursor: pointer;
      }
      .levels {
        list-style: none;
        padding: 0;
        margin: 32px 0;
        display: flex;
        flex-direction: column;
        gap: 16px;
      }
      .level-card {
        text-align: left;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        padding: 20px;
        background: #f8fafc;
        transition: transform 200ms ease, box-shadow 200ms ease;
      }
      .level-card.is-link {
        cursor: pointer;
      }
      .level-card.is-link:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 30px rgba(15, 23, 42, 0.12);
      }
      .word-progress {
        margin-top: 8px;
        font-size: 0.9rem;
        color: #1e293b;
      }
      .flashcard-link {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        margin-top: 12px;
        font-weight: 600;
        color: #0ea5e9;
        text-decoration: none;
      }
      .flashcard-link::after {
        content: '\2192';
        font-size: 0.95rem;
      }
      .level-head {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-weight: 600;
        color: #0f172a;
      }
      .level-head span:last-child {
        color: #0369a1;
      }
      .progress {
        height: 10px;
        border-radius: 999px;
        background: #e2e8f0;
        margin: 12px 0;
        overflow: hidden;
      }
      .progress-bar {
        height: 100%;
        background: linear-gradient(90deg, #0ea5e9, #6366f1);
      }
      .level-card p {
        margin: 0;
        color: #475569;
        font-size: 0.95rem;
      }
    
      @media (max-width: 520px) {
        body {
          padding: 16px;
        }
        .card, .wrap, .box {
          padding: 24px 18px;
          width: 100% !important;
        }
        h1 {
          font-size: 1.35rem;
        }
      }
    </style>
  </head>
  <body>
    <div class="wrap">
      <h1>Hallo <%= currentUser?.email %>!</h1>
      <p>Welcome to the Learning German dashboard. From here you can plug in future vocabulary or progress tracking features.</p>
      <ul class="levels">
        <% levels.forEach(function(level) { %>
          <li class="level-card <%= level.flashcardHref ? 'is-link' : '' %>" <%= level.flashcardHref ? `onclick=\"window.location='${level.flashcardHref}'\"` : '' %>>
            <div class="level-head">
              <span><%= level.code %> · <%= level.title %></span>
              <span><%= level.completion %>%</span>
            </div>
            <div class="progress">
              <div class="progress-bar" style="width:<%= level.completion %>%"></div>
            </div>
            <p><%= level.summary %></p>
            <% if (level.wordStats && level.wordStats.total) { %>
              <p class="word-progress">Wortschatz gelernt: <%= level.wordStats.learned %> / <%= level.wordStats.total %> (<%= level.learnedPercent %>%)</p>
            <% } %>
            <% if (level.flashcardHref) { %>
              <a class="flashcard-link" href="<%= level.flashcardHref %>">Flashcards starten</a>
            <% } %>
          </li>
        <% }) %>
      </ul>
      <form method="POST" action="/logout">
        <button type="submit">Log out</button>
      </form>
    </div>
  </body>
</html>
