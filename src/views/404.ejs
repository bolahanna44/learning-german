<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Not found</title>
    <style>
      body {
        font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        margin: 0;
        background: #f1f5f9;
      }
      .box {
        text-align: center;
        padding: 32px;
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 15px 45px rgba(15, 23, 42, 0.12);
      }
      a {
        color: #2563eb;
        text-decoration: none;
        font-weight: 600;
      }
    </style>
  </head>
  <body>
    <div class="box">
      <h1>404</h1>
      <p>Die Seite wurde nicht gefunden.</p>
      <p><a href="/">Zurück zur Startseite</a></p>
    </div>
  </body>
</html>
